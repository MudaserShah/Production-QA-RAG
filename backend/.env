# Copy this file to .env and fill in your real values
# NEVER commit .env to git — only commit .env.example

# OpenAI
OPENAI_API_KEY=

# Qdrant Cloud (from cloud.qdrant.io)
QDRANT_URL=
QDRANT_API_KEY=

# Collection name (must exist in Qdrant — created in Lecture 8)
QDRANT_COLLECTION=document_butler

# Embedding provider: "huggingface" (free, default) or "openai" (paid)
EMBEDDING_PROVIDER=huggingface

# LLM model
LLM_MODEL=gpt-4o-mini

# Number of chunks to retrieve per query
RETRIEVER_K=5
